{
  "version": 2,
  "rewrites": [
    { "source": "/lib/runtime.bin", "destination": "/assets/wasm/main.wasm" },
    { "source": "/api/v1/metrics", "destination": "/api/log" }
  ],
  "headers": [
    {
      "source": "/lib/runtime.bin",
      "headers": [
        { "key": "Content-Type", "value": "application/wasm" },
        { "key": "Access-Control-Allow-Origin", "value": "*" }
      ]
    }
  ]
}